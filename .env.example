# Application
NODE_ENV=development
API_PORT=4000
JWT_SECRET=SECRET
JWT_EXPIRATION=3600
FRONTEND_DOMAIN=http://localhost:3000

# Database
DB_HOST=localhost                 #your database host
DB_PORT=5432                      #your database port
DB_USERNAME=postgres              #your database username
DB_PASSWORD=root                  #your database password
DB_NAME=vitrine_produtos_db       #your database name
DATABASE_URL=postgres://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}      #your database connection string
